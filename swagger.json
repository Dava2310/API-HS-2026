  "info": {
    "title": "API Documentation",
    "description": "API - IT Asset Tracker",
    "version": "0.0.1",
    "contact": {}
  },
  "tags": [
    {
      "name": "api",
      "description": ""
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "MessageResponseDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Mensaje de respuesta",
            "example": "Solicitud exitosa"
          }
        },
        "required": [
          "message"
        ]
      },
      "CreateEmployeeDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "description": "Employee full name",
            "example": "John Doe",
            "minLength": 3,
            "maxLength": 100
          },
          "employeeCode": {
            "type": "string",
            "description": "Unique employee code (exactly 10 characters)",
            "example": "EMP0012345",
            "minLength": 10,
            "maxLength": 10
          },
          "email": {
            "type": "string",
            "description": "Employee email address",
            "example": "john.doe@company.com",
            "maxLength": 100,
            "format": "email"
          },
          "password": {
            "type": "string",
            "description": "Employee password",
            "example": "SecurePassword123",
            "minLength": 8,
            "maxLength": 100,
            "format": "password"
          },
          "roleId": {
            "type": "number",
            "description": "Role identifier (foreign key)",
            "example": 1
          }
        },
        "required": [
          "fullName",
          "employeeCode",
          "email",
          "password",
          "roleId"
        ]
      },
      "EmployeeResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "Unique employee identifier",
            "example": 1,
            "readOnly": true
          },
          "fullName": {
            "type": "string",
            "description": "Employee full name",
            "example": "John Doe",
            "maxLength": 100
          },
          "employeeCode": {
            "type": "string",
            "description": "Unique employee code",
            "example": "EMP0012345",
            "minLength": 10,
            "maxLength": 10
          },
          "email": {
            "type": "string",
            "description": "Employee email address",
            "example": "john.doe@company.com",
            "maxLength": 100,
            "format": "email"
          },
          "createdAt": {
            "type": "string",
            "description": "When the record was created",
            "example": "2024-06-15T10:30:00.000Z",
            "format": "date-time"
          },
          "deletedAt": {
            "type": "string",
            "description": "Soft-delete timestamp; null while the record is active",
            "nullable": true,
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "fullName",
          "employeeCode",
          "email",
          "createdAt",
          "deletedAt"
        ]
      },
      "UpdateEmployeeDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "description": "Employee full name",
            "example": "John Doe",
            "minLength": 3,
            "maxLength": 100
          },
          "employeeCode": {
            "type": "string",
            "description": "Unique employee code (exactly 10 characters)",
            "example": "EMP0012345",
            "minLength": 10,
            "maxLength": 10
          },
          "email": {
            "type": "string",
            "description": "Employee email address",
            "example": "john.doe@company.com",
            "maxLength": 100,
            "format": "email"
          },
          "password": {
            "type": "string",
            "description": "Employee password",
            "example": "SecurePassword123",
            "minLength": 8,
            "maxLength": 100,
            "format": "password"
          },
          "roleId": {
            "type": "number",
            "description": "Role identifier (foreign key)",
            "example": 1
          }
        }
      },
      "CreateAssetDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the asset",
            "example": "MacBook Pro 14\"",
            "minLength": 1,
            "maxLength": 100
          },
          "sku": {
            "type": "string",
            "description": "Unique stock keeping unit (SKU) code for the asset",
            "example": "MBP-2024-001",
            "minLength": 3,
            "maxLength": 20
          },
          "description": {
            "type": "string",
            "description": "Description of the asset",
            "example": "Company laptop for development",
            "maxLength": 500
          },
          "model": {
            "type": "string",
            "description": "Model of the asset",
            "example": "MacBook Pro",
            "minLength": 1,
            "maxLength": 100
          },
          "brand": {
            "type": "string",
            "description": "Brand of the asset",
            "example": "Apple",
            "minLength": 1,
            "maxLength": 100
          },
          "categoryId": {
            "type": "number",
            "description": "ID of the category this asset belongs to",
            "example": 1
          },
          "employeeId": {
            "type": "number",
            "description": "ID of the employee assigned as custodian of this asset",
            "example": 1
          }
        },
        "required": [
          "name",
          "sku",
          "description",
          "model",
          "brand",
          "categoryId",
          "employeeId"
        ]
      },
      "AssetResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "Unique asset identifier",
            "example": 1,
            "readOnly": true
          },
          "sku": {
            "type": "string",
            "description": "Unique stock keeping unit (SKU) code for the asset",
            "example": "MBP-2024-001",
            "minLength": 3,
            "maxLength": 20
          },
          "name": {
            "type": "string",
            "description": "Name of the asset",
            "example": "MacBook Pro 14\"",
            "maxLength": 100
          },
          "description": {
            "type": "string",
